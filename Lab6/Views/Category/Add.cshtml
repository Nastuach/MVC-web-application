@model Lab6.Models.Category


<style>
    .category-container {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .category-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding: 1rem 0;
        border-bottom: 1px solid #eee;
        width: 100%;
        max-width: 800px;
    }

    .category-title {
        font-size: 1.8rem;
        font-weight: 500;
        color: #2c3e50;
    }

    .category-table-wrapper {
        width: 100%;
        max-width: 800px;
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .btn-custom {
        padding: 0.5rem 1.5rem;
        border-radius: 6px;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid #e0e0e0;
        background: #f8f9fa;
        color: #2c3e50;
        min-width: 160px;
        justify-content: center;
        white-space: nowrap;
        flex: 1;
    }

        .btn-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 3px 8px rgba(0,0,0,0.05);
            background: #fff;
        }

    .btn-primary {
        background-color: #4a90e2;
        color: white;
        border: none;
    }

        .btn-primary:hover {
            background-color: #357abd;
        }

    .category-actions {
        display: flex;
        gap: 1rem;
        width: 100%;
    }

    .form-row {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        color: #6c757d;
        font-weight: 500;
    }

    .form-input,
    .form-textarea {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        font-size: 1rem;
        transition: border-color 0.2s;
    }

        .form-input:focus,
        .form-textarea:focus {
            outline: none;
            border-color: #4a90e2;
            box-shadow: 0 0 0 2px rgba(74, 144, 226, 0.1);
        }

    .form-textarea {
        resize: vertical;
        min-height: 100px;
    }

    .validation-error {
        color: #dc3545;
        font-size: 0.875rem;
        margin-top: 0.5rem;
        display: block;
    }
</style>

<div class="category-container">
    <div class="category-header">
        <h1 class="category-title">Новая категория</h1>
    </div>

    <div class="category-table-wrapper">
        <form asp-action="Add" class="form-container">
            <div asp-validation-summary="ModelOnly" class="validation-error"></div>

            <div class="form-row">
                <label class="form-label" asp-for="Title">Название</label>
                <input asp-for="Title" class="form-input" />
                <span asp-validation-for="Title" class="validation-error"></span>
            </div>

            <div class="form-row">
                <label class="form-label" asp-for="Description">Описание</label>
                <textarea asp-for="Description" class="form-textarea"></textarea>
                <span asp-validation-for="Description" class="validation-error"></span>
            </div>

            <div class="category-actions">
                <button type="submit" class="btn-custom btn-primary">
                    <i class="bi bi-plus-circle"></i>
                    Создать
                </button>
                <a asp-action="All" class="btn-custom btn-details">
                    <i class="bi bi-arrow-left"></i>
                    Отмена
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}