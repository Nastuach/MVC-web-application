@{
    ViewData["Title"] = "Главное меню";
}

<style>
    .nav-card {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        transition: all 0.3s ease;
        background: #f8f9fa;
        margin: 1rem 0;
        width: 100%;
        max-width: 400px;
    }

        .nav-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            background: #fff;
        }

    .nav-link {
        padding: 1.5rem;
        text-decoration: none;
        color: #2c3e50;
        display: block;
        text-align: center;
    }

    .nav-title {
        font-size: 1.25rem;
        font-weight: 500;
        margin: 0;
    }

    .center-container {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 2rem;
    }
</style>

<div class="center-container">
    <h1 class="display-5 mb-5 text-center">Тест</h1>
    <div class="d-flex flex-column align-items-center w-100">
        <div class="nav-card">
            <a asp-controller="Question" asp-action="All" class="nav-link">
                <h3 class="nav-title">Работа с карточками</h3>
            </a>
        </div>

        <div class="nav-card">
            <a asp-controller="Category" asp-action="All" class="nav-link">
                <h3 class="nav-title">Работа с категориями</h3>
            </a>
        </div>

        <div class="nav-card">
            <a asp-controller="Question" asp-action="Start" class="nav-link">
                <h3 class="nav-title">Тестирование</h3>
            </a>
        </div>

        <div class="nav-card">
            <a asp-controller="Question" asp-action="Export" class="nav-link">
                <h3 class="nav-title">Экспорт данных</h3>
            </a>
        </div>
    </div>
</div>