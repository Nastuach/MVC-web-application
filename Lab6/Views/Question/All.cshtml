@model IEnumerable<Lab6.Models.Question>

@{
    ViewData["Title"] = "Все вопросы";
    Layout = "_Layout";
}

<style>
    .category-container {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .category-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding: 1rem 0;
        border-bottom: 1px solid #eee;
        width: 100%;
        max-width: 800px;
    }

    .category-title {
        font-size: 1.8rem;
        font-weight: 500;
        color: #2c3e50;
    }

    .btn-custom {
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        border: 1px solid #e0e0e0;
        background: #f8f9fa;
        color: #2c3e50;
        text-decoration: none;
    }

        .btn-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 3px 8px rgba(0,0,0,0.05);
            background: #fff;
        }

    .btn-edit {
        border-color: #4a90e2;
        color: #4a90e2;
    }

    .btn-details {
        border-color: #6c757d;
        color: #6c757d;
    }

    .btn-delete {
        border-color: #dc3545;
        color: #dc3545;
    }

    .btn-home {
        border-color: #28a745;
        color: #28a745;
    }

    .category-table-wrapper {
        width: 100%;
        max-width: 800px;
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .table-header {
        background: #f8f9fa;
        color: #6c757d;
        font-weight: 500;
    }

    .table-row:hover {
        background-color: #f8f9fa;
    }

    .action-buttons {
        display: flex;
        gap: 0.8rem;
        justify-content: center;
        align-items: center;
    }

    .home-link {
        margin-top: 2rem;
        display: flex;
        justify-content: center;
    }
</style>

<div class="category-container">
    <div class="category-header">
        <a asp-action="Add" class="btn-custom">+ Новый вопрос</a>
    </div>

    <div class="category-table-wrapper">
        <table class="table">
            <thead class="table-header">
                <tr>
                    <th>№</th>
                    <th>Текст</th>
                    <th>Комментарий</th>
                    <th>Категория</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="table-row">
                        <td>@item.Id</td>
                        <td>@item.Text</td>
                        <td>@item.Comment</td>
                        <td>@item.Category?.Title</td>
                        <td>
                            <div class="action-buttons">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-custom btn-edit">Изменить</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn-custom btn-details">Подробно</a>
                                <a asp-action="Remove" asp-route-id="@item.Id" class="btn-custom btn-delete">Удалить</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="home-link">
        <a href="/" class="btn-custom btn-home">⟵ Вернуться на главную</a>
    </div>
</div>
