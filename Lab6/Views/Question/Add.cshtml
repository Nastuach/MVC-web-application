@model Lab6.Models.Question
@{
    Layout = "_Layout";
}

<style>
    .category-container {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .category-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding: 1rem 0;
        border-bottom: 1px solid #eee;
        width: 100%;
        max-width: 800px;
    }

    .category-title {
        font-size: 1.8rem;
        font-weight: 500;
        color: #2c3e50;
    }

    .category-table-wrapper {
        width: 100%;
        max-width: 800px;
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .btn-primary,
    .btn-custom {
        padding: 0.6rem 1.5rem;
        font-size: 0.9rem;
        min-width: 160px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        white-space: nowrap;
    }

    .btn-primary {
        background-color: #4a90e2;
        color: white;
        border: none;
    }

        .btn-primary:hover {
            background-color: #357abd;
        }

    .btn-custom {
        border: 1px solid #e0e0e0;
        background: #f8f9fa;
        color: #2c3e50;
    }

        .btn-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 3px 8px rgba(0,0,0,0.05);
            background: #fff;
        }

    .category-actions {
        display: flex;
        gap: 1rem;
        width: 100%;
        justify-content: center;
    }

    .form-row {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        color: #6c757d;
        font-weight: 500;
    }

    .form-input,
    .form-textarea {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        font-size: 1rem;
        transition: border-color 0.2s;
    }

        .form-input:focus,
        .form-textarea:focus {
            outline: none;
            border-color: #4a90e2;
            box-shadow: 0 0 0 2px rgba(74, 144, 226, 0.1);
        }

    .form-textarea {
        resize: vertical;
        min-height: 100px;
    }

    .validation-error {
        color: #dc3545;
        font-size: 0.875rem;
        margin-top: 0.5rem;
        display: block;
    }
</style>

<div class="category-container">
    <div class="category-header">
        <h1 class="category-title">Создать новый вопрос</h1>
    </div>

    <div class="category-table-wrapper">
        <form asp-action="Add">
            <div asp-validation-summary="ModelOnly" class="text-danger validation-error"></div>

            <div class="form-row">
                <label class="form-label">Текст вопроса</label>
                <input asp-for="Text" class="form-input" />
                <span asp-validation-for="Text" class="text-danger validation-error"></span>
            </div>

            <div class="form-row">
                <label class="form-label">Комментарий</label>
                <input asp-for="Comment" class="form-input" />
                <span asp-validation-for="Comment" class="text-danger validation-error"></span>
            </div>

            <div class="form-row">
                <label class="form-label">Категория</label>
                <select asp-for="CategoryId" class="form-input" asp-items="ViewBag.CategoryId"></select>
            </div>

            <div class="form-group">
                <label class="control-label">Правильные ответы</label>
                <input name="Answers" class="form-control"
                       value="@(Model.Answers != null ? string.Join(", ", Model.Answers) : "")" />
            </div>

            <div class="form-group">
                <label class="control-label">Неправильные ответы</label>
                <input name="BadAnswers" class="form-control"
                       value="@(Model.BadAnswers != null ? string.Join(", ", Model.BadAnswers) : "")" />
            </div>

            <div class="form-row">
                <button type="submit" class="btn btn-primary">Создать</button>
            </div>
        </form>
    </div>

    <div class="category-actions">
        <a asp-action="All" class="btn btn-custom">Вернуться к списку</a>
    </div>
</div>